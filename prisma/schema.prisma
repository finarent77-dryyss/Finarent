// Finarent — Schema v3.0 (Mars 2026)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────
enum Role {
  CLIENT
  ADMIN
  PARTNER
  INSURER
}

enum ProductType {
  PRET_PRO      // Prêt professionnel
  CREDIT_BAIL   // Crédit-bail
  LOA           // Location avec Option d'Achat
  LLD           // Location Longue Durée
  LEASING_OPS   // Leasing Opérationnel
  RC_PRO        // RC Professionnelle (assurance)
}

enum PartnerType {
  BANK
  INSURANCE
  LEASING
}

enum ApplicationStatus {
  PENDING           // Soumis, non traité
  REVIEWING         // Admin analyse
  DOCUMENTS_NEEDED  // Client doit compléter
  QUOTE_SENT        // Devis envoyé au client
  QUOTE_ACCEPTED    // Client a accepté le devis
  PENDING_SIGNATURE // En attente de signature
  SIGNED            // Contrat signé
  TRANSMITTED       // Dossier reversé au partenaire
  APPROVED          // Partenaire a validé
  REJECTED          // Dossier refusé
  COMPLETED         // Fonds débloqués / couverture active
}

enum DocumentType {
  KBIS
  RIB
  CNI
  BILAN
  CONTRAT
  AUTRE
}

enum OfferStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REFUSED
  EXPIRED
  SIGNED
}

// ─── MODELS ───────────────────────────────────────────────
model User {
  id           String        @id @default(cuid())
  auth0Id      String        @unique
  email        String        @unique
  name         String?
  phone        String?
  company      String?
  legalForm    String?
  role         Role          @default(CLIENT)
  partnerId    String?
  partner      Partner?      @relation(fields: [partnerId], references: [id])
  applications Application[]
  messages     Message[]
  referralsMade Referral[]   @relation("referrer")
  referralCode  String?      @unique
  lastLoginAt  DateTime?
  invoices     Invoice[]
  quotes       Quote[]
  creditNotes  CreditNote[]
  signaturesToSign  SignatureRequest[] @relation("SignatureRequestTo")
  signaturesRequested SignatureRequest[] @relation("SignatureRequestBy")
  documentAccesses  DocumentAccess[] @relation("DocumentAccessedBy")
  rgpdActions       RgpdAction[]     @relation("UserRgpdActions")
  callCenterMemberships CallCenterMember[] @relation("CallCenterMemberships")
  callCenterInteractions CallCenterInteraction[] @relation("CallCenterAgent")
  assignedProspects     Prospect[]         @relation("ProspectAssignedAgent")
  adminActivityLogs     AdminActivityLog[] @relation("AdminActivityActor")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Partner {
  id           String        @id @default(cuid())
  name         String
  type         PartnerType
  contactEmail String
  isActive     Boolean       @default(true)
  notes        String?
  users        User[]
  applications Application[]
  commissions  Commission[]
  offers       Offer[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Application {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id])
  productType   ProductType
  status        ApplicationStatus @default(PENDING)
  amount        Float?
  duration      Int?
  equipmentType String?
  siren         String?
  companyName   String?
  legalForm     String?
  sector        String?
  description   String?
  quoteDetails  Json?
  partnerId     String?
  partner       Partner?          @relation(fields: [partnerId], references: [id])
  adminNotes    String?
  transmittedAt DateTime?
  scorePreQual  Int?              @default(0)
  scoreLabel    String?
  // Affiliation : commercial qui a ramené cette demande
  affiliateId   String?
  affiliate     Affiliate?        @relation(fields: [affiliateId], references: [id])
  affiliateCommissions AffiliateCommission[]
  // Rattachement à un centre d'appel
  callCenterId  String?
  callCenter    CallCenter?       @relation("CallCenterApplications", fields: [callCenterId], references: [id])
  callCenterCommission CallCenterCommission? @relation("CallCenterCommissionApp")
  callCenterInteractions CallCenterInteraction[] @relation("CallCenterInteractions")
  documents     Document[]
  messages      Message[]
  statusHistory StatusHistory[]
  commissions   Commission[]
  offers        Offer[]
  invoices      Invoice[]
  quotes        Quote[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([createdAt])
  @@index([updatedAt])
  @@index([sector])
  @@index([productType])
  @@index([status, createdAt])
  @@index([status, updatedAt])
  @@index([callCenterId])
  @@index([affiliateId])
}

model Offer {
  id              String       @id @default(cuid())
  applicationId   String
  application     Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  amount          Float
  durationMonths  Int
  monthlyPayment  Float
  rate            Float
  totalCost       Float
  partnerId       String?
  partner         Partner?     @relation(fields: [partnerId], references: [id])
  conditions      Json?
  status          OfferStatus  @default(DRAFT)
  expiresAt       DateTime
  sentAt          DateTime?
  viewedAt        DateTime?
  acceptedAt      DateTime?
  signatureUrl    String?
  signedAt        DateTime?
  createdBy       String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status, expiresAt])
  @@index([status, sentAt])
}

model Document {
  id            String       @id @default(cuid())
  applicationId String
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  uploadedById  String
  type          DocumentType @default(AUTRE)
  fileName      String
  fileUrl       String       // Chemin Supabase Storage
  fileSize      Int
  mimeType      String
  // Soft-delete : on conserve le record 30 jours pour rétention légale
  deletedAt     DateTime?
  deletedById   String?
  accesses      DocumentAccess[]
  createdAt     DateTime     @default(now())

  @@index([deletedAt])
}

// Audit trail RGPD : qui a consulté/téléchargé quel document, quand, d'où
model DocumentAccess {
  id           String   @id @default(cuid())
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  accessedById String
  accessedBy   User     @relation("DocumentAccessedBy", fields: [accessedById], references: [id])
  action       String   // UPLOAD | VIEW | DOWNLOAD | DELETE
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([documentId, createdAt])
  @@index([accessedById])
  @@index([action])
}

// Audit trail RGPD : export, suppression, rectification, consentement
enum RgpdActionType {
  EXPORT
  DELETE_ACCOUNT
  RECTIFY
  CONSENT_GRANT
  CONSENT_REVOKE
}

model RgpdAction {
  id        String         @id @default(cuid())
  userId    String?
  user      User?          @relation("UserRgpdActions", fields: [userId], references: [id])
  email     String?        // pour les actions sans user (newsletter unsubscribe par exemple)
  action    RgpdActionType
  details   Json?
  ip        String?
  userAgent String?
  createdAt DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([action])
}

model Message {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  senderId      String
  sender        User        @relation(fields: [senderId], references: [id])
  content       String
  isAdminOnly   Boolean     @default(false)
  readAt        DateTime?
  createdAt     DateTime    @default(now())
}

model StatusHistory {
  id            String            @id @default(cuid())
  applicationId String
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  changedById   String
  fromStatus    ApplicationStatus
  toStatus      ApplicationStatus
  comment       String?
  createdAt     DateTime          @default(now())

  @@index([applicationId])
  @@index([changedById])
  @@index([toStatus])
  @@index([fromStatus, toStatus])
}

model Commission {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  partnerId     String
  partner       Partner     @relation(fields: [partnerId], references: [id])
  amount        Float
  rate          Float
  status        String      @default("PENDING")
  paidAt        DateTime?
  createdAt     DateTime    @default(now())

  @@index([partnerId])
  @@index([status])
  @@index([partnerId, status])
  @@index([partnerId, createdAt])
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("general")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Referral {
  id           String    @id @default(cuid())
  referrerId   String
  referrer     User      @relation("referrer", fields: [referrerId], references: [id])
  refereeEmail String
  refereeName  String?
  status       String    @default("PENDING")
  code         String    @unique
  createdAt    DateTime  @default(now())
  convertedAt  DateTime?
}

model Testimonial {
  id          String   @id @default(cuid())
  authorName  String
  initials    String
  position    String?
  company     String?
  sector      String?
  rating      Int      @default(5)
  text        String
  amount      String?
  isPublished Boolean  @default(false)
  isApproved  Boolean  @default(false)
  rejectedAt  DateTime?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, isApproved])
}

// ─── FACTURATION ──────────────────────────────────────────
// Inspiré du modèle slformations : Invoice + lignes + versements + avoirs.
// Adapté à Finarent (frais de dossier client, honoraires courtage).

model Invoice {
  id            String          @id @default(cuid())
  invoiceNumber String          @unique
  issueDate     DateTime        @default(now())
  dueDate       DateTime?
  paymentTerms  String?
  // status : DRAFT | ISSUED | PARTIAL | PAID | CANCELLED
  status        String          @default("DRAFT")
  // Client (snapshot — peut différer si client modifie son profil après émission)
  clientName    String
  clientEmail   String?
  clientPhone   String?
  clientAddress String?
  clientPostal  String?
  clientCity    String?
  clientSiret   String?
  // Liens optionnels
  userId        String?
  user          User?           @relation(fields: [userId], references: [id])
  applicationId String?
  application   Application?    @relation(fields: [applicationId], references: [id])
  // Totaux
  totalHT       Float           @default(0)
  totalTVA      Float           @default(0)
  totalTTC      Float           @default(0)
  paidAmount    Float           @default(0)
  paidAt        DateTime?
  paymentMethod String?
  pdfUrl               String?
  notes                String?
  sentAt               DateTime?
  sentTo               String?
  archivedAt           DateTime?
  stripePaymentLinkId  String?
  stripePaymentLinkUrl String?
  createdAt            DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  lines         InvoiceLine[]
  payments      InvoicePayment[]
  creditNotes   CreditNote[]

  @@index([status])
  @@index([userId])
  @@index([applicationId])
  @@index([issueDate])
}

model InvoiceLine {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  vatRate     Float    @default(20)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoicePayment {
  id            String   @id @default(cuid())
  invoiceId     String
  amount        Float
  paidAt        DateTime @default(now())
  paymentMethod String   // CB | virement | chèque | espèces | avoir
  reference     String?  // numéro chèque, ID virement, etc.
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([paidAt])
}

model CreditNote {
  id               String   @id @default(cuid())
  creditNoteNumber String   @unique
  invoiceId        String?
  userId           String?
  reason           String
  amount           Float
  usedAmount       Float    @default(0)
  status           String   @default("DRAFT") // DRAFT | ACTIVE | USED | EXPIRED | CANCELLED
  expiresAt        DateTime?
  pdfUrl           String?
  issuedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  invoice          Invoice? @relation(fields: [invoiceId], references: [id])
  user             User?    @relation(fields: [userId], references: [id])

  @@index([invoiceId])
  @@index([userId])
  @@index([status])
}

// ─── DEVIS (Quote) ─────────────────────────────────────────
// Distinct du modèle Offer (qui représente une offre de prêt partenaire).
// Quote = proposition commerciale Finarent (frais courtage, honoraires).

model Quote {
  id               String     @id @default(cuid())
  quoteNumber      String     @unique
  userId           String?
  user             User?      @relation(fields: [userId], references: [id])
  applicationId    String?
  application      Application? @relation(fields: [applicationId], references: [id])
  // Client snapshot
  companyName      String?
  companyAddress   String?
  companySiret     String?
  contactName      String
  contactEmail     String
  contactPhone     String?
  // Workflow
  status           String     @default("DRAFT") // DRAFT | SENT | ACCEPTED | REFUSED | EXPIRED
  validUntil       DateTime
  subtotalHT       Float      @default(0)
  taxRate          Float      @default(20)
  taxAmount        Float      @default(0)
  totalTTC         Float      @default(0)
  discountPercent  Float?
  discountAmount   Float?
  paymentTerms     String?
  notes            String?
  sentAt           DateTime?
  acceptedAt       DateTime?
  refusedAt        DateTime?
  refusalReason    String?
  pdfUrl           String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  items            QuoteItem[]

  @@index([status])
  @@index([userId])
  @@index([applicationId])
  @@index([createdAt])
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  description String
  quantity    Int      @default(1)
  unitPriceHT Float
  totalHT     Float
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

// ─── SIGNATURE ÉLECTRONIQUE ────────────────────────────────
// Tracker des signatures envoyées via YouSign, hors-ligne ou autres.

model SignatureRequest {
  id                String    @id @default(cuid())
  documentType      String    // OFFER | QUOTE | CONTRACT | INVOICE | OTHER
  documentId        String
  requestedToId     String
  requestedById     String
  status            String    @default("PENDING") // PENDING | SIGNED | REFUSED | EXPIRED
  provider          String    @default("yousign") // yousign | manual
  providerRefId     String?   // ID externe YouSign
  signUrl           String?
  signatureData     String?   // base64 signature image (si signature manuscrite manuelle)
  signedAt          DateTime?
  signedByIp        String?
  signedByUserAgent String?
  token             String    @unique
  expiresAt         DateTime
  refusalReason     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  requestedTo       User      @relation("SignatureRequestTo", fields: [requestedToId], references: [id])
  requestedBy       User      @relation("SignatureRequestBy", fields: [requestedById], references: [id])

  @@index([token])
  @@index([documentType, documentId])
  @@index([requestedToId])
  @@index([status])
}

// ─── TEMPLATES DOCUMENTS ───────────────────────────────────

model DocumentTemplate {
  id            String   @id @default(cuid())
  type          String   // INVOICE | QUOTE | CONTRACT | RECEIPT
  name          String
  logoUrl       String?
  headerColor   String?  @default("#0A192F")
  footerText    String?
  legalMentions String?
  htmlTemplate  String
  variables     Json     @default("[]")
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type, isDefault])
}

// ─── PROSPECT — leads issus des simulateurs (cookie tracking) ──
enum ProspectStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

model Prospect {
  id             String          @id @default(cuid())
  anonId         String          @unique             // UUID cookie côté navigateur
  email          String?
  phone          String?
  name           String?
  company        String?
  status         ProspectStatus  @default(NEW)
  source         String?                              // utm_source, referrer
  // Attribution marketing — premier touch, jamais écrasé
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmTerm        String?
  utmContent     String?
  referrer       String?                              // document.referrer du 1er hit
  landingPage    String?                              // URL d'atterrissage
  // Score d'engagement (recalculé serveur à chaque event)
  engagementScore Int           @default(0)
  ipAddress      String?
  userAgent      String?
  notes          String?
  assignedToId   String?                              // admin/sales en charge
  convertedUserId String?                             // si converti en user
  // Affiliation : commercial / apporteur d'affaires qui a ramené ce prospect
  affiliateId    String?
  affiliate      Affiliate?      @relation(fields: [affiliateId], references: [id])
  // Rattachement à un centre d'appel + agent en charge (file de prospection téléphonique)
  callCenterId   String?
  callCenter     CallCenter?     @relation("CallCenterProspects", fields: [callCenterId], references: [id], onDelete: SetNull)
  assignedAgentId String?
  assignedAgent  User?           @relation("ProspectAssignedAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  // Suivi téléphonie (sync Ringover ou log manuel centre d'appel)
  callAttempts    Int           @default(0)
  lastCallAt      DateTime?
  lastCallOutcome String?       // NO_ANSWER | CALLBACK | INTERESTED | NOT_INTERESTED | ANSWERED | VOICEMAIL
  callCenterInteractions CallCenterInteraction[] @relation("CallCenterInteractions")
  events         ProspectEvent[]
  firstSeenAt    DateTime        @default(now())
  lastSeenAt     DateTime        @default(now())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status])
  @@index([lastSeenAt])
  @@index([email])
  @@index([affiliateId])
  @@index([engagementScore])
  @@index([utmSource])
  @@index([callCenterId])
  @@index([assignedAgentId])
}

model ProspectEvent {
  id            String   @id @default(cuid())
  prospectId    String
  prospect      Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  simulatorSlug String                              // ex: capacite-emprunt
  category      String?                             // ex: credit-immobilier
  params        Json                                // valeurs du simulateur (montant, durée, taux, etc.)
  result        Json?                               // résultat principal (capacité, mensualité…)
  url           String?
  createdAt     DateTime @default(now())

  @@index([prospectId, createdAt])
  @@index([simulatorSlug])
}

// ─── AFFILIATION — Apporteurs d'affaires internes ─────────
// Système de tracking pour les commerciaux/apporteurs internes Finarent.
// Flow : visiteur arrive avec ?ref=CODE → cookie 90 jours → tout Prospect/Application
// créé pendant la période est attribué à l'affilié → commission auto sur SIGNED.

enum AffiliateCommissionType {
  FIXED      // montant fixe en € par dossier signé
  PERCENT    // pourcentage du montant financé
}

enum AffiliateCommissionStatus {
  PENDING    // dossier signé, commission calculée, en attente de paiement
  PAID       // commission versée à l'apporteur
  CANCELLED  // dossier annulé / refusé
}

model Affiliate {
  id                String                @id @default(cuid())
  code              String                @unique          // slug court utilisé dans ?ref=CODE
  name              String
  email             String                @unique
  phone             String?
  // Configuration commission
  commissionType    AffiliateCommissionType @default(FIXED)
  commissionValue   Float                 @default(0)      // € si FIXED, % si PERCENT (0-100)
  // Visibilité publique
  isActive          Boolean               @default(true)
  publicStatsEnabled Boolean              @default(true)   // permet d'exposer /affiliate/[code]
  notes             String?
  // Relations
  clicks            AffiliateClick[]
  prospects         Prospect[]
  applications      Application[]
  commissions       AffiliateCommission[]
  invites           AffiliateInvite[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([isActive])
  @@index([email])
}

// Invitations / parrainages envoyés via l'affilié (single ou bulk CSV)
enum AffiliateInviteStatus {
  SENT       // email expédié SMTP
  CLICKED    // le destinataire a cliqué sur le lien (matché via cookie côté track)
  CONVERTED  // un prospect ou une application a été créé après le clic
  FAILED     // échec d'envoi SMTP
}

enum AffiliateInviteSource {
  AFFILIATE_PAGE  // envoyé depuis /affiliate/[code]
  ADMIN_SINGLE    // envoyé par l'admin depuis /admin/affiliates/[id]
  ADMIN_BULK      // import CSV admin
}

model AffiliateInvite {
  id              String                @id @default(cuid())
  affiliateId     String
  affiliate       Affiliate             @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  recipientEmail  String
  recipientName   String?
  message         String?               // message personnalisé (300 chars max)
  source          AffiliateInviteSource
  status          AffiliateInviteStatus @default(SENT)
  failedReason    String?
  sentAt          DateTime              @default(now())
  convertedAt     DateTime?
  convertedProspectId String?
  convertedApplicationId String?
  createdAt       DateTime              @default(now())

  @@index([affiliateId, sentAt])
  @@index([recipientEmail])
  @@index([status])
}

// Log des clics sur un lien d'affiliation (?ref=CODE)
model AffiliateClick {
  id          String    @id @default(cuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  landingPath String?                   // ex: "/simulateurs/credit-bail"
  referer     String?
  ip          String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@index([affiliateId, createdAt])
}

// Commission calculée à la signature d'une application
model AffiliateCommission {
  id            String                    @id @default(cuid())
  affiliateId   String
  affiliate     Affiliate                 @relation(fields: [affiliateId], references: [id])
  applicationId String
  application   Application               @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  // Snapshot des conditions au moment du calcul (immuable même si l'affilié change ses taux)
  type          AffiliateCommissionType
  rate          Float                                       // value du taux au moment du calcul
  amount        Float                                       // montant final calculé en €
  status        AffiliateCommissionStatus @default(PENDING)
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@unique([applicationId])  // une seule commission par dossier
  @@index([affiliateId, status])
  @@index([status, createdAt])
}

// ─── CENTRES D'APPEL ──────────────────────────────────────
// Hiérarchie : Centre → 1 Manager + N Agents
// Un centre peut être INTERNAL (équipe Finarent) ou EXTERNAL (partenaire télémarketing)
// Quand un agent du centre crée/qualifie une demande, celle-ci est attribuée
// au centre. À la signature → commission auto pour le centre (le manager
// répartit ensuite manuellement entre ses agents hors plateforme).

enum CallCenterType {
  INTERNAL  // équipe interne Finarent (ex: "Centre Paris")
  EXTERNAL  // société partenaire externe (télémarketing, prestataire)
}

enum CallCenterMemberRole {
  MANAGER  // gère le centre, voit les stats, ajoute/retire des agents
  AGENT    // passe des appels, qualifie les demandes
}

model CallCenter {
  id              String                  @id @default(cuid())
  code            String                  @unique          // ex: CC-PARIS, CC-LYON, CC-CALLZONE
  name            String
  type            CallCenterType          @default(INTERNAL)
  // Coordonnées
  address         String?
  phone           String?
  email           String?
  // Externe uniquement : pour les virements de commission
  iban            String?
  // Configuration commission (par défaut PERCENT 5%)
  commissionType  AffiliateCommissionType @default(PERCENT)
  commissionValue Float                   @default(5)
  isActive        Boolean                 @default(true)
  notes           String?
  // Relations
  members         CallCenterMember[]
  applications    Application[]           @relation("CallCenterApplications")
  prospects       Prospect[]              @relation("CallCenterProspects")
  interactions    CallCenterInteraction[]
  commissions     CallCenterCommission[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([type, isActive])
  @@index([isActive])
}

model CallCenterMember {
  id            String                @id @default(cuid())
  callCenterId  String
  callCenter    CallCenter            @relation(fields: [callCenterId], references: [id], onDelete: Cascade)
  userId        String
  user          User                  @relation("CallCenterMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role          CallCenterMemberRole  @default(AGENT)
  isActive      Boolean               @default(true)
  joinedAt      DateTime              @default(now())

  @@unique([callCenterId, userId])
  @@index([userId])
  @@index([callCenterId, role])
}

// Log des interactions (appels, emails, SMS) déclenchées par un agent
// Étend le système existant /api/admin/centre-appel/log avec rattachement
// explicite à un centre et à un agent.
model CallCenterInteraction {
  id            String        @id @default(cuid())
  callCenterId  String?
  callCenter    CallCenter?   @relation(fields: [callCenterId], references: [id], onDelete: SetNull)
  agentId       String?
  agent         User?         @relation("CallCenterAgent", fields: [agentId], references: [id], onDelete: SetNull)
  prospectId    String?
  prospect      Prospect?     @relation("CallCenterInteractions", fields: [prospectId], references: [id], onDelete: SetNull)
  applicationId String?
  application   Application?  @relation("CallCenterInteractions", fields: [applicationId], references: [id], onDelete: SetNull)
  channel       String        // CALL | EMAIL | SMS
  direction     String?       // INBOUND | OUTBOUND
  outcome       String?       // ANSWERED | MISSED | VOICEMAIL | INTERESTED | NOT_INTERESTED | CALLBACK | NO_SHOW
  durationSec   Int?
  notes         String?
  callbackAt    DateTime?     // si outcome = CALLBACK
  // Sync téléphonie (Ringover, etc.) — inspiré SL Formations
  provider      String        @default("MANUAL") // MANUAL | RINGOVER | OTHER
  externalId    String?       // idempotence webhook (ex. ringover:channel:hangup)
  summary       String?       // libellé lisible (ex. Ringover · Sortant · Décroché · 42s)
  metadata      Json?
  occurredAt    DateTime?     // horodatage réel de l'appel (≠ createdAt si sync différée)
  createdAt     DateTime      @default(now())

  @@index([callCenterId, createdAt])
  @@index([agentId, createdAt])
  @@index([prospectId])
  @@index([applicationId])
  @@index([outcome])
  @@index([provider, occurredAt])
  @@index([externalId, provider])
}

// Commission calculée à la signature d'une demande attribuée à un centre
// ─── JOURNAL D'ACTIVITÉ OWNER ─────────────────────────────
// Journal centralisé des actions sensibles de l'admin/owner (best-effort,
// ne bloque jamais l'action métier). Agrégé dans /admin/logs avec les audits
// RGPD (RgpdAction) et l'historique des statuts (StatusHistory).
// Inspiré du modèle slformations (AdminActivityLog).
model AdminActivityLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AdminActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  module     String   // security | finance | settings | demandes | crm | call_center | affiliations | exports | rgpd
  action     String   // ex: COMMISSION_PAID, PROSPECT_ASSIGNED, EXPORT, CENTER_CREATED…
  entityType String?  // ex: CallCenterCommission, Prospect, Application
  entityId   String?
  summary    String   // phrase lisible (max 500)
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([module])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
}

model CallCenterCommission {
  id            String                    @id @default(cuid())
  callCenterId  String
  callCenter    CallCenter                @relation(fields: [callCenterId], references: [id])
  applicationId String                    @unique
  application   Application               @relation("CallCenterCommissionApp", fields: [applicationId], references: [id], onDelete: Cascade)
  type          AffiliateCommissionType
  rate          Float                                       // snapshot au moment du calcul
  amount        Float
  status        AffiliateCommissionStatus @default(PENDING)
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@index([callCenterId, status])
  @@index([status, createdAt])
}
