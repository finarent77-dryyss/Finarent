// Finassur — Schema v3.0 (Mars 2026)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────
enum Role {
  CLIENT
  ADMIN
  PARTNER
  INSURER
}

enum ProductType {
  PRET_PRO      // Prêt professionnel
  CREDIT_BAIL   // Crédit-bail
  LOA           // Location avec Option d'Achat
  LLD           // Location Longue Durée
  LEASING_OPS   // Leasing Opérationnel
  RC_PRO        // RC Professionnelle (assurance)
}

enum PartnerType {
  BANK
  INSURANCE
  LEASING
}

enum ApplicationStatus {
  PENDING           // Soumis, non traité
  REVIEWING         // Admin analyse
  DOCUMENTS_NEEDED  // Client doit compléter
  QUOTE_SENT        // Devis envoyé au client
  QUOTE_ACCEPTED    // Client a accepté le devis
  PENDING_SIGNATURE // En attente de signature
  SIGNED            // Contrat signé
  TRANSMITTED       // Dossier reversé au partenaire
  APPROVED          // Partenaire a validé
  REJECTED          // Dossier refusé
  COMPLETED         // Fonds débloqués / couverture active
}

enum DocumentType {
  KBIS
  RIB
  CNI
  BILAN
  CONTRAT
  AUTRE
}

// ─── MODELS ───────────────────────────────────────────────
model User {
  id           String        @id @default(cuid())
  auth0Id      String        @unique
  email        String        @unique
  name         String?
  phone        String?
  company      String?
  legalForm    String?
  role         Role          @default(CLIENT)
  partnerId    String?
  partner      Partner?      @relation(fields: [partnerId], references: [id])
  applications Application[]
  messages     Message[]
  referralsMade Referral[]   @relation("referrer")
  referralCode  String?      @unique
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Partner {
  id           String        @id @default(cuid())
  name         String
  type         PartnerType
  contactEmail String
  isActive     Boolean       @default(true)
  notes        String?
  users        User[]
  applications Application[]
  commissions  Commission[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Application {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id])
  productType   ProductType
  status        ApplicationStatus @default(PENDING)
  amount        Float?
  duration      Int?
  equipmentType String?
  siren         String?
  companyName   String?
  legalForm     String?
  sector        String?
  description   String?
  quoteDetails  Json?
  partnerId     String?
  partner       Partner?          @relation(fields: [partnerId], references: [id])
  adminNotes    String?
  transmittedAt DateTime?
  documents     Document[]
  messages      Message[]
  statusHistory StatusHistory[]
  commissions   Commission[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Document {
  id            String       @id @default(cuid())
  applicationId String
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  uploadedById  String
  type          DocumentType @default(AUTRE)
  fileName      String
  fileUrl       String       // Chemin Supabase Storage
  fileSize      Int
  mimeType      String
  createdAt     DateTime     @default(now())
}

model Message {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  senderId      String
  sender        User        @relation(fields: [senderId], references: [id])
  content       String
  isAdminOnly   Boolean     @default(false)
  readAt        DateTime?
  createdAt     DateTime    @default(now())
}

model StatusHistory {
  id            String            @id @default(cuid())
  applicationId String
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  changedById   String
  fromStatus    ApplicationStatus
  toStatus      ApplicationStatus
  comment       String?
  createdAt     DateTime          @default(now())
}

model Commission {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  partnerId     String
  partner       Partner     @relation(fields: [partnerId], references: [id])
  amount        Float
  rate          Float
  status        String      @default("PENDING")
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("general")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Referral {
  id           String    @id @default(cuid())
  referrerId   String
  referrer     User      @relation("referrer", fields: [referrerId], references: [id])
  refereeEmail String
  refereeName  String?
  status       String    @default("PENDING")
  code         String    @unique
  createdAt    DateTime  @default(now())
  convertedAt  DateTime?
}
