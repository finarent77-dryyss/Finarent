# Auth0 - Next.js
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_SECRET=run_openssl_rand_hex_32
APP_BASE_URL=http://localhost:3000

# reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Base de données PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/finassur"

# Supabase Storage (documents)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# SMTP (Nodemailer - emails transactionnels)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM=noreply@finassur.fr
ADMIN_EMAIL=admin@finassur.fr

# YouSign (signature électronique)
YOUSIGN_API_KEY=your_yousign_api_key
YOUSIGN_BASE_URL=https://api.yousign.com

# Sentry (error monitoring)
NEXT_PUBLIC_SENTRY_DSN=

# PostHog (product analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
