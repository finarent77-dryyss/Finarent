# ============================================================
# Finarent — Variables d'environnement (modèle)
# ============================================================
# cp .env.example .env  puis remplir les valeurs
# ============================================================

# --- URL application ---
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth0 ---
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_SECRET=run_openssl_rand_hex_32
AUTH0_BASE_URL=http://localhost:3000

# --- Base de données PostgreSQL ---
DATABASE_URL="postgresql://user:password@localhost:5432/finarent"

# --- Chiffrement AES-256-GCM ---
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=replace_with_base64_32_bytes_random_key

# --- reCAPTCHA v3 ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# --- SMTP (Nodemailer — confirmations, invitations affiliés) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM=noreply@finarent.fr
ADMIN_EMAIL=admin@finarent.fr

# --- Ringover (centre d'appels) ---
# API : Calls Write + Monitoring activés
# Webhook URL : https://VOTRE-DOMAINE/api/webhooks/ringover
RINGOVER_API_KEY=
RINGOVER_WEBHOOK_KEY=
RINGOVER_SMS_FROM_NUMBER=+33XXXXXXXXX

# --- Brevo (emails prospection call-center + sync marketing) ---
# Webhook URL : https://VOTRE-DOMAINE/api/webhooks/brevo?token=VOTRE_TOKEN
BREVO_API_KEY=
BREVO_SENDER_EMAIL=ne-pas-repondre@finarent.fr
BREVO_SENDER_NAME=Finarent — Centre d'appels
BREVO_MARKETING_LIST_ID=
BREVO_WEBHOOK_TOKEN=

# --- Stockage documents : Clever Cloud Cellar (S3) — prioritaire ---
# Injecté automatiquement par l'addon Cellar sur Clever Cloud.
CELLAR_ADDON_HOST=cellar-c2.services.clever-cloud.com
CELLAR_ADDON_KEY_ID=your_cellar_key_id
CELLAR_ADDON_KEY_SECRET=your_cellar_key_secret
CELLAR_BUCKET=finarent-docs-kyc

# --- Supabase Storage (fallback si Cellar absent) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- YouSign (signature électronique) ---
YOUSIGN_API_KEY=your_yousign_api_key
YOUSIGN_BASE_URL=https://api.yousign.com

# --- Twilio (SMS — optionnel) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Stripe (paiement factures) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Cron Vercel ---
CRON_SECRET=

# --- Monitoring ---
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
